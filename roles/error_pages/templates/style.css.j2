body {
    font: 75% verdana, "Bitstream Vera Sans", geneva, arial, helvetica, helve, sans-serif;
    color: #303030;
    padding: 0;
    border: 0;
    margin: 0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

div.pageTitle {
    font-size: x-large;
    font-weight: bold;
}

div.pageTitle a:link, div.pageTitle a:visited, div.pageTitle a:active, div.pageTitle a:hover {
    text-decoration: none;
    color: #ece7f2;
}

div.masthead {
    vertical-align: middle;
    background: #2c3143;
    height: 40px;
    padding-left: 10px;
    display: flex;
    align-items: center;
    flex-shrink: 0;
}

div.content {
    vertical-align: top;
    background: #d2d9ed;
    padding: 10px;
    flex: 1;
}

a:link, a:visited, a:active {
    color: #303030;
}
